# Copy to .env on the server. Do not commit the real .env file.

# App
NODE_ENV=production
PORT=5000
APP_URL=https://staging.jconthemove.com
SESSION_SECRET=replace-with-a-random-32-plus-character-secret

# Caddy / HTTPS
SITE_DOMAIN=staging.jconthemove.com
ACME_EMAIL=upmichiganstatemovers@gmail.com

# PostgreSQL container defaults.
# If you change POSTGRES_PASSWORD, update DATABASE_URL to match.
POSTGRES_USER=jconthemove
POSTGRES_PASSWORD=replace-with-a-strong-database-password
POSTGRES_DB=jconthemove
DATABASE_URL=postgresql://jconthemove:replace-with-a-strong-database-password@db:5432/jconthemove

# Square payments
SQUARE_ENVIRONMENT=sandbox
SQUARE_ACCESS_TOKEN=replace-with-square-token

# Company defaults
COMPANY_EMAIL=upmichiganstatemovers@gmail.com
COMPANY_PHONE=906-285-9312
ADMIN_EMAIL=upmichiganstatemovers@gmail.com
ADMIN_PHONE_NUMBER=

# Email / SMS integrations
SENDGRID_API_KEY=
GMAIL_USER=
GMAIL_APP_PASSWORD=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# Google integrations
GOOGLE_MAPS_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://staging.jconthemove.com/api/auth/google/callback
GOOGLE_APPLICATION_CREDENTIALS_JSON=
GOOGLE_CLOUD_PROJECT_ID=

# JCMOVES / crypto features
MOONSHOT_TOKEN_ADDRESS=
TREASURY_WALLET_PUBLIC_KEY=
TREASURY_WALLET_PRIVATE_KEY=
VITE_SOLANA_RPC_URL=
BTC_WALLET_ADDRESS=

# Browser push notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:upmichiganstatemovers@gmail.com
VITE_VAPID_PUBLIC_KEY=

# Native/mobile builds only, normally blank for same-origin web hosting.
VITE_API_BASE_URL=

# Render deploy repair / manual trigger tooling.
# Preferred: create a Render deploy hook for branch main and paste it here locally,
# and add the same value as GitHub Actions secret RENDER_DEPLOY_HOOK_URL.
RENDER_DEPLOY_HOOK_URL=
# Fallback if using Render API instead of a deploy hook.
RENDER_API_KEY=
RENDER_SERVICE_ID=
PUBLIC_HEALTH_URL=https://jc-on-the-move.onrender.com/health
RENDER_READINESS_URL=https://jc-on-the-move.onrender.com/api/health
CUSTOM_DOMAIN_HEALTH_URL=https://www.jconthemove.com/health
# CI requires a Render hook/API trigger by default. Set this to false only
# after Render Git auto-deploy is confirmed healthy.
REQUIRE_RENDER_TRIGGER=true
