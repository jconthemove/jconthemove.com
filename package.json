  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "build": "npm run build:client && npm run build:server && node scripts/write-build-info.mjs",
    "build:client": "vite build",
    "build:server": "esbuild server/index.ts --platform=node --target=node20 --format=esm --bundle --packages=external --alias:@shared=./shared --outdir=dist",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "verify:production": "node scripts/check-production-deploy.mjs",
    "check": "cross-env NODE_OPTIONS=--max-old-space-size=8192 tsc --incremental false",
    "test:server": "node scripts/run-server-tests.mjs",
    "db:push": "drizzle-kit push"
  },
